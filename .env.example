# Avalon Backend Environment Variables

# --- For Cloud APIs (OpenAI, etc.) ---
# AVALON_MODEL_API_KEY="sk-..."
# AVALON_MODEL_API_BASE="https://api.openai.com/v1"
# AVALON_MODEL_NAME="gpt-4o-mini"

# --- For Local Models (Ollama, LM Studio, llama.cpp, etc.) ---
# Most local inference servers expose an OpenAI-compatible endpoint.
# Just point AVALON_MODEL_API_BASE at your local server. No key needed.

# Ollama (enable OpenAI compat in Ollama settings, usually http://localhost:11434/v1)
# AVALON_MODEL_API_BASE="http://localhost:11434/v1"
# AVALON_MODEL_NAME="llama3"

# LM Studio (default local server URL)
# AVALON_MODEL_API_BASE="http://localhost:1234/v1"
# AVALON_MODEL_NAME="local-model"

# llama.cpp server
# AVALON_MODEL_API_BASE="http://localhost:8080/v1"
# AVALON_MODEL_NAME="local-model"
